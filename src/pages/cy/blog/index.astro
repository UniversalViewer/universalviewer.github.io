---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '@i18n/utils';
import type { Lang } from '@i18n/ui';
import { siteConfig } from '@config/site';
import { getBlogPosts } from '@utils/blog';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogPostItem from '@components/BlogPostItem.astro';

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);
const blogPageTwoUrl = getRelativeLocaleUrl(locale, '/blog/page/2');

const posts = await getBlogPosts({ sort: true, locale: 'cy' });

const pageTitle = 'Blog';
const morePages = Math.ceil(posts.length / siteConfig.blog.postsPerPage) > 1;
const postsToShow = posts.slice(0, siteConfig.blog.postsPerPage);
---

<BaseLayout
  pageTitle={pageTitle}
  mainClass="blog-index-main"
>
  <header class="blog-header">
    <div class="blog-hero">
      <h1>{t('blog.heading')}</h1>
    </div>
  </header>

  <section class="post-list">
    {
      postsToShow.length > 0 ? (
        <ul>
          {postsToShow.map((post) => (
            <BlogPostItem post={post} />
          ))}
        </ul>
      ) : (
        <p>No posts</p>
      )
    }
    {
      morePages && (
        <nav class="pagination blog-pagination">
          <a href={blogPageTwoUrl}>{t('blog.olderPosts')} &rarr;</a>
        </nav>
      )
    }
  </section>
</BaseLayout>
