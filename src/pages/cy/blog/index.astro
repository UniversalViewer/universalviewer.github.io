---
import { getCollection } from 'astro:content';
import { siteConfig, blogCollectionLocales } from '@config/site';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogPostItem from '@components/BlogPostItem.astro';

// TODO: Make helper function for this that accepts default and optional locale posts
const defaultPosts = await getCollection(blogCollectionLocales['en']);
const localePosts = await getCollection(blogCollectionLocales['cy']);

const postsMap = new Map();

for (const post of defaultPosts) {
  postsMap.set(post.id, post);
}

for (const post of localePosts) {
  postsMap.set(post.id, post);
}

const posts = Array.from(postsMap.values());
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = 'Blog';
const morePages = Math.ceil(posts.length / siteConfig.blog.postsPerPage) > 1;
const postsToShow = posts.slice(0, siteConfig.blog.postsPerPage);
---

<BaseLayout
  pageTitle={pageTitle}
  mainClass="blog-index-main"
>
  <header class="blog-header">
    <div class="blog-hero">
      <h1>Blog</h1>
    </div>
  </header>

  <section class="post-list">
    {
      postsToShow.length > 0 ? (
        <ul>
          {postsToShow.map((post) => (
            <BlogPostItem post={post} />
          ))}
        </ul>
      ) : (
        <p>No posts</p>
      )
    }
    {
      morePages && (
        <nav class="pagination blog-pagination">
          <a href="/cy/blog/page/2">Older posts →</a>
        </nav>
      )
    }
  </section>
</BaseLayout>
