---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogLayout from '@layouts/BlogLayout.astro';
import { siteConfig, blogCollectionLocales } from '@config/site';

export async function getStaticPaths() {
  const defaultPosts = await getCollection(blogCollectionLocales['en']);
  const localePosts = await getCollection(blogCollectionLocales['cy']);

  const postsMap = new Map();

  for (const post of defaultPosts) {
    postsMap.set(post.id, post);
  }

  for (const post of localePosts) {
    postsMap.set(post.id, post);
  }

  const posts = Array.from(postsMap.values());

  return posts.map((post) => {
    const d = new Date(post.data.date);
    const year = d.getFullYear().toString();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');

    return {
      params: {
        year,
        month,
        day,
        language: post.data.language,
        id: post.id,
      },
      props: { post },
    };
  });
}

const { id, language } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);

// 1. Load all posts
const posts = await getCollection('blog');

// 2. sort newest first
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 3. Find current post
const index = posts.findIndex((p) => p.id === id);
const entry = posts[index];
if (!entry) throw new Error(`Post not found: ${id}`);

// 4. Compute previous & next
const prev = posts[index + 1]; // because sorted descending
const next = posts[index - 1];
---

<BaseLayout
  pageTitle={post.data.title}
  mainClass="blog-post-main"
>
  <BlogLayout
    post={post}
    prev={prev}
    next={next}
  >
    <Content />
  </BlogLayout>
</BaseLayout>
