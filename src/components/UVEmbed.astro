---
import { useTranslations } from '@i18n/utils';
import type { Lang } from '@i18n/ui';
import { uvLocales } from '@config/uv';

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const uvLocale = uvLocales[locale];
---

<!-- UV embed -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <h2 class="hero-heading">{t('home.viewer.heading')}</h2>
    <iframe
      id="uv"
      src={`https://universalviewer.dev/uv.html#?manifest=https%3A%2F%2Fwellcomelibrary.org%2Fiiif%2Fb18035723%2Fmanifest&locales=${uvLocale}`}
      allowfullscreen
      frameborder="0"
      title="Universal Viewer"
    ></iframe>
    <div class="manifest-input">
      <input
        type="text"
        id="manifest-url"
        placeholder="Paste a IIIF manifest URL…"
      />
      <button id="manifest-load">{t('home.viewer.view')}</button>
    </div>
  </div>
</section>
