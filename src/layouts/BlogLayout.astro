---
import { Image } from 'astro:assets';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '@i18n/ui';
import { useTranslations, getLocaleISOString } from '@i18n/utils';

interface Props {
  post: any;
  prev?: any;
  next?: any;
}

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const { post, prev, next } = Astro.props;

const { title, date, author } = post.data;

const localeISOString = getLocaleISOString(locale);

const formattedDate = date.toLocaleDateString(localeISOString, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

function postUrl(p: any) {
  const d = new Date(p.data.date);
  return getRelativeLocaleUrl(
    locale,
    `/blog/${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/${p.id}`
  );
}
---

<article>
  <header>
    <p class="post-date">
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </p>
    <h1>{title}</h1>
    {
      post.data.cover && post.data.coverAlt && (
        <div class="post-cover">
          <Image
            src={post.data.cover}
            alt={post.data.coverAlt}
          />
        </div>
      )
    }
    {
      author && (
        <p>
          <span class="post-author">{author}</span>
        </p>
      )
    }
  </header>
  <slot />
  <nav class="post-nav">
    {
      prev && (
        <div class="prev-post">
          <>
            <strong>{t('blog.previousPost')}</strong>
            <br />
          </>
          <a href={postUrl(prev)}>{prev.data.title}</a>
        </div>
      )
    }
    {
      next && (
        <div class="next-post">
          <>
            <strong>{t('blog.nextPost')}</strong>
            <br />
          </>
          <a href={postUrl(next)}>{next.data.title}</a>
        </div>
      )
    }
  </nav>
</article>
